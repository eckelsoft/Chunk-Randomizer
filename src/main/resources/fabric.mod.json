{
  "schemaVersion": 1,
  "id": "chunkblockmod",
  "version": "${version}",
  "name": "ChunkBlockMod",
  "description": "Every chunk you visit is randomized to a new blocktype!",
  "authors": ["Eckelsoft"],
  "contact": {
    "homepage": "https://modrinth.com/mod/chunk-randomizer",
    "sources": "https://github.com/eckelsoft/Chunk-Randomizer"
  },

  "license": "All-Rights-Reserved",
  "icon": "assets/chunkblockmod/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
    ],
    "client": [
      "org.eckelsoft.chunkblockmod.client.ChunkblockmodClient"
    ],
    "main": [
      "org.eckelsoft.chunkblockmod.Chunkblockmod"
    ]
  },
  "mixins": [
    "chunkblockmod.mixins.json",
    {
      "config": "chunkblockmod.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${min_fabric_api_version}",
    "minecraft": ">=1.21.9 <=1.21.11"
  }
}
